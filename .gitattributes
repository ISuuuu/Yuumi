# 强制 LF，避免 Windows CRLF 污染
* text=auto eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 二进制文件不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary