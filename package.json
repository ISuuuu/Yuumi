{
  "name": "yuumi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "type-check": "vue-tsc --noEmit",
    "format": "cd src-tauri && cargo fmt --all",
    "fmt-check": "cd src-tauri && cargo fmt --all -- --check",
    "clippy": "cd src-tauri && cargo clippy --all-targets -- -D warnings",
    "test:rust": "cd src-tauri && cargo test",
    "check-all": "pnpm run format && pnpm type-check && pnpm fmt-check && pnpm clippy",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@vicons/ionicons5": "^0.13.0",
    "marked": "^18.0.5",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.8",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.3",
    "husky": "^9.1.7",
    "typescript": "~5.7.2",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
