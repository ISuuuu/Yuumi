{
  "$schema": "https://raw.githubusercontent.com/nicklasoverworlds/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Yuumi",
  "version": "0.0.0",
  "identifier": "com.yuumi.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Yuumi",
        "width": 1200,
        "height": 910,
        "center": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "devtools": true
      },
      {
        "label": "bench-overlay",
        "url": "index.html?window=bench-overlay",
        "title": "Yuumi - ARAM Bench",
        "width": 550,
        "height": 70,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; connect-src 'self' https://127.0.0.1:* https://api.github.com https://game.gtimg.cn; font-src 'self' https: data:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzQjk5RURCMTE1MTM5MEIKUldRTE9WRVIyNTY1Z3pVZWRIQzh1bythRWZ3bWJsdTdoeS9uUTEvL0ZBa3I1bXZEd1o3cWpRbTYK",
      "active": true,
      "endpoints": [
        "https://github.com/ISuuuu/Yuumi/releases/latest/download/latest.json",
        "https://ghp.ci/https://github.com/ISuuuu/Yuumi/releases/latest/download/latest.json"
      ]      
    }
  }
}
